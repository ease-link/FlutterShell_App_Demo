{
  "name": "Favorites",
  "root": {
    "id": "root",
    "type": "column",
    "props": {
      "background": "#F3F3F3",
      "padding": {
        "bottom": 20,
        "left": 20,
        "right": 20,
        "top": 20
      },
      "crossAxisAlignment": "start"
    },
    "children": [
      {
        "id": "title",
        "type": "text",
        "bind": "favoritesCount",
        "props": {
          "style": {
            "color": "#1C1B1F",
            "fontSize": 18,
            "weight": "bold"
          },
          "value": "You have {{favoritesCount}} favorites:"
        },
        "children": []
      },
      {
        "id": "sp1",
        "type": "vspacer",
        "props": {
          "height": 16
        },
        "children": []
      },
      {
        "id": "favorites_list",
        "type": "list_view",
        "bind": "favorites",
        "props": {
          "item_template": {
            "type": "row",
            "id": "fav_item",
            "children": [
              {
                "id": "fav_icon",
                "type": "icon",
                "props": {
                  "color": "#6750A4",
                  "name": "favorite",
                  "size": 20
                },
                "children": []
              },
              {
                "props": {
                  "width": 12
                },
                "children": [],
                "type": "hspacer",
                "id": "fav_sp"
              },
              {
                "type": "text",
                "bind": ".",
                "props": {
                  "style": {
                    "fontSize": 14,
                    "color": "#1C1B1F"
                  },
                  "value": "{{.}}"
                },
                "id": "fav_text",
                "children": []
              }
            ],
            "props": {
              "padding": {
                "bottom": 8,
                "top": 8
              },
              "crossAxisAlignment": "center"
            }
          },
          "shrinkWrap": true
        },
        "children": []
      }
    ]
  }
}