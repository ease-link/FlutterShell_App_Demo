{
  "name": "Generator",
  "scrollable": false,
  "root": {
    "id": "root",
    "type": "column",
    "props": {
      "mainAxisAlignment": "center",
      "background": "#F3F3F3",
      "padding": {
        "right": 20,
        "left": 20
      },
      "crossAxisAlignment": "center"
    },
    "children": [
      {
        "id": "hint",
        "type": "text",
        "props": {
          "style": {
            "color": "#49454F",
            "fontSize": 14
          },
          "value": "A random idea:"
        },
        "children": []
      },
      {
        "id": "sp1",
        "type": "vspacer",
        "props": {
          "height": 16
        },
        "children": []
      },
      {
        "id": "big_card",
        "type": "card",
        "props": {
          "padding": {
            "right": 32,
            "left": 32,
            "bottom": 20,
            "top": 20
          },
          "elevation": 4,
          "color": "#6750A4",
          "borderRadius": 12
        },
        "children": [
          {
            "id": "word_pair",
            "type": "text",
            "bind": "currentWord",
            "props": {
              "style": {
                "letterSpacing": 1.5,
                "color": "#F3EFF4",
                "weight": "bold",
                "fontSize": 28
              },
              "value": "{{currentWord}}"
            },
            "children": []
          }
        ]
      },
      {
        "id": "sp2",
        "type": "vspacer",
        "props": {
          "height": 24
        },
        "children": []
      },
      {
        "id": "buttons_row",
        "type": "row",
        "props": {
          "mainAxisAlignment": "center"
        },
        "children": [
          {
            "id": "like_btn",
            "type": "button",
            "props": {
              "label": "Like",
              "variant": "elevated",
              "action": {
                "name": "toggleFavorite",
                "type": "action"
              },
              "icon": "favorite"
            },
            "children": []
          },
          {
            "id": "sp3",
            "type": "hspacer",
            "props": {
              "width": 16
            },
            "children": []
          },
          {
            "id": "next_btn",
            "type": "button",
            "props": {
              "action": {
                "name": "getNext",
                "type": "action"
              },
              "variant": "elevated",
              "label": "Next",
              "icon": "skip_next"
            },
            "children": []
          }
        ]
      }
    ]
  }
}