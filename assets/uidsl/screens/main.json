{
  "name": "Main",
  "scrollable": false,
  "root": {
    "id": "root",
    "type": "navigation_rail",
    "bind": "selectedNavIndex",
    "props": {
      "selectedIndex": 0,
      "action": {
        "name": "selectNav",
        "type": "action"
      },
      "destinations": [
        {
          "label": "Home",
          "icon": "home"
        },
        {
          "label": "Favorites",
          "icon": "favorite"
        }
      ],
      "background": "#E8DEF8"
    },
    "children": [
      {
        "id": "generator_page",
        "type": "column",
        "props": {
          "padding": {
            "right": 20,
            "left": 20
          },
          "crossAxisAlignment": "center",
          "background": "#F3F3F3",
          "mainAxisAlignment": "center"
        },
        "children": [
          {
            "id": "hint",
            "type": "text",
            "props": {
              "style": {
                "fontSize": 14,
                "color": "#49454F"
              },
              "value": "A random idea:"
            },
            "children": []
          },
          {
            "id": "sp1",
            "type": "vspacer",
            "props": {
              "height": 16
            },
            "children": []
          },
          {
            "id": "big_card",
            "type": "card",
            "props": {
              "color": "#6750A4",
              "padding": {
                "bottom": 20,
                "right": 32,
                "left": 32,
                "top": 20
              },
              "elevation": 4,
              "borderRadius": 12
            },
            "children": [
              {
                "id": "word_pair",
                "type": "text",
                "bind": "currentWord",
                "props": {
                  "style": {
                    "letterSpacing": 1.5,
                    "color": "#F3EFF4",
                    "weight": "bold",
                    "fontSize": 28
                  },
                  "value": "{{currentWord}}"
                },
                "children": []
              }
            ]
          },
          {
            "id": "sp2",
            "type": "vspacer",
            "props": {
              "height": 24
            },
            "children": []
          },
          {
            "id": "buttons_row",
            "type": "row",
            "props": {
              "mainAxisAlignment": "center"
            },
            "children": [
              {
                "id": "like_btn",
                "type": "button",
                "props": {
                  "label": "Like",
                  "icon": "favorite",
                  "variant": "elevated",
                  "action": {
                    "type": "functionCall",
                    "name": "toggleFavorite"
                  }
                },
                "children": []
              },
              {
                "id": "sp3",
                "type": "hspacer",
                "props": {
                  "width": 16
                },
                "children": []
              },
              {
                "id": "next_btn",
                "type": "button",
                "props": {
                  "variant": "elevated",
                  "label": "Next",
                  "icon": "skip_next",
                  "action": {
                    "type": "functionCall",
                    "name": "getNext",
                    "storeKey": "currentWord"
                  }
                },
                "children": []
              }
            ]
          }
        ]
      },
      {
        "id": "favorites_page",
        "type": "column",
        "props": {
          "crossAxisAlignment": "start",
          "padding": {
            "left": 20,
            "top": 20,
            "right": 20,
            "bottom": 20
          },
          "background": "#F3F3F3"
        },
        "children": [
          {
            "id": "fav_title",
            "type": "text",
            "props": {
              "style": {
                "weight": "bold",
                "fontSize": 18,
                "color": "#1C1B1F"
              },
              "value": "You have {{favoritesCount}} favorites:"
            },
            "children": []
          },
          {
            "id": "sp_fav",
            "type": "vspacer",
            "props": {
              "height": 16
            },
            "children": []
          },
          {
            "id": "favorites_list",
            "type": "list_view",
            "bind": "favorites",
            "props": {
              "item_template": {
                "id": "fav_item",
                "type": "row",
                "props": {
                  "crossAxisAlignment": "center",
                  "padding": {
                    "bottom": 8,
                    "top": 8
                  }
                },
                "children": [
                  {
                    "id": "fav_icon",
                    "props": {
                      "size": 20,
                      "name": "favorite",
                      "color": "#6750A4"
                    },
                    "type": "icon",
                    "children": []
                  },
                  {
                    "type": "hspacer",
                    "props": {
                      "width": 12
                    },
                    "children": [],
                    "id": "fav_sp"
                  },
                  {
                    "props": {
                      "style": {
                        "fontSize": 14,
                        "color": "#1C1B1F"
                      },
                      "value": "{{.}}"
                    },
                    "type": "text",
                    "id": "fav_text",
                    "children": [],
                    "bind": "."
                  }
                ]
              },
              "shrinkWrap": true
            },
            "children": []
          }
        ]
      }
    ]
  }
}